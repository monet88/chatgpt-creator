{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types", "vitest"],
    "strict": true,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true
  },
  "include": ["src", "tests"]
}
